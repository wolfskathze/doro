---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout title="Impressum">
  <PageHero
    eyebrow="Rechtliches"
    title="Impressum"
    text="Platzhalter für die gesetzlich erforderlichen Angaben. Vor Veröffentlichung bitte mit echten Daten ersetzen."
  />

  <section class="section legal-copy">
    <h2>Angaben gemäß TMG</h2>
    <p>Katharina Kluge<br />Bingerstr. 37<br />76185 Karlsruhe</p>
    <h2>Kontakt</h2>
    <p>E-Mail: kontakt@galerie-spunst.example</p>
    <h2>Hinweis</h2>
    <p>Diese Angaben sind Platzhalter und müssen vor einer öffentlichen Nutzung rechtlich geprüft werden.</p>
  </section>
</BaseLayout>
