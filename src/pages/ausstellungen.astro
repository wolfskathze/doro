---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstagramLink from "../components/InstagramLink.astro";
import PageHero from "../components/PageHero.astro";
import { exhibitions } from "../data/site";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const archiveItems = [...exhibitions].reverse();
---

<BaseLayout title="Ausstellungen">
  <PageHero
    eyebrow="Programm"
    title="Vergangene Ausstellungen"
    text="Ein wachsendes Archiv der Studierenden Galerie Spunst mit Flyern, Orten, Kooperationen, beteiligten Künstlern und späteren Installationsansichten."
  />

  <section class="section exhibition-archive">
    {archiveItems.map((item) => (
      <article>
        <a class="exhibition-image-link" href={`${base}ausstellungen/${item.slug}/`}>
          <img src={`${base}${item.image}`} alt={item.alt} loading="lazy" />
        </a>
        <div>
          <p class="card-meta">{item.category} / {item.dates}</p>
          <h2><a href={`${base}ausstellungen/${item.slug}/`}>{item.title}</a></h2>
          <p class="card-kicker">{item.artist} / {item.venue}</p>
          <p>{item.text} {item.collaboration}.</p>
          <div class="link-row">
            <a class="text-link" href={`${base}ausstellungen/${item.slug}/`}>Mehr zur Ausstellung</a>
            <InstagramLink href={item.instagram} />
          </div>
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
