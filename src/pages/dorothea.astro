---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---

<BaseLayout title="Dorothea Spunst" description="Persona, Lebenslauf und akademische Laufbahn der Galeristin Dorothea Spunst.">
  <PageHero
    eyebrow="Galeristin"
    title="Dorothea Spunst"
    text="Kunsthistorikerin, Kuratorin und Galeristin mit Schwerpunkt auf zeitgenoessischer Malerei, Papierarbeiten und kuenstlerischer Vermittlung."
  />

  <section class="section timeline-section">
    <div>
      <p class="eyebrow">Lebenslauf</p>
      <h2>Akademische und kuratorische Laufbahn</h2>
    </div>
    <ol class="timeline">
      <li>
        <span>2010-2014</span>
        <p>Studium der Kunstgeschichte und Kulturwissenschaften mit Schwerpunkt Ausstellungspraxis.</p>
      </li>
      <li>
        <span>2015-2018</span>
        <p>Wissenschaftliche Mitarbeit in Sammlungs- und Galerieprojekten, Recherche zu Kuenstlernachlaessen.</p>
      </li>
      <li>
        <span>2019-2024</span>
        <p>Freie kuratorische Arbeit, Atelierbesuche, Publikationen und Aufbau eines Netzwerks junger Positionen.</p>
      </li>
      <li>
        <span>seit 2026</span>
        <p>Gruendung der Studierenden Galerie Spunst als Ort fuer Ausstellungen, Editionen und direkte Kunstvermittlung.</p>
      </li>
    </ol>
  </section>
</BaseLayout>
