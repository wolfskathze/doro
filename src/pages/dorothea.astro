---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Dorothea Spunst" description="Persona, Lebenslauf und akademische Laufbahn der Galeristin Dorothea Spunst.">
  <PageHero
    eyebrow="Galeristin"
    title="Dorothea Spunst"
    text="Kunsthistorikerin, Kuratorin und Galeristin mit Schwerpunkt auf zeitgenössischer Malerei, Papierarbeiten und künstlerischer Vermittlung."
  />

  <section class="section portrait-section">
    <figure>
      <img src={`${base}assets/portraits/dorothea-spunst.jpg`} alt="Dorothea Spunst in einer schwarz-weißen Porträtaufnahme" />
    </figure>
    <div class="copy-block">
      <p class="eyebrow">Porträt</p>
      <h2>Dorothea Spunst arbeitet zwischen kuratorischer Haltung, Einladung und performativer Präsenz.</h2>
      <p>
        Das Bild dient als erster visueller Anker für die Galeristin. Text, Bildunterschrift
        und biografische Details können später noch genauer auf Dorotheas tatsächliche
        Laufbahn abgestimmt werden.
      </p>
    </div>
  </section>

  <section class="section timeline-section">
    <div>
      <p class="eyebrow">Lebenslauf</p>
      <h2>Akademische und kuratorische Laufbahn</h2>
    </div>
    <ol class="timeline">
      <li>
        <span>2010-2014</span>
        <p>Studium der Kunstgeschichte und Kulturwissenschaften mit Schwerpunkt Ausstellungspraxis.</p>
      </li>
      <li>
        <span>2015-2018</span>
        <p>Wissenschaftliche Mitarbeit in Sammlungs- und Galerieprojekten, Recherche zu Künstlernachlässen.</p>
      </li>
      <li>
        <span>2019-2024</span>
        <p>Freie kuratorische Arbeit, Atelierbesuche, Publikationen und Aufbau eines Netzwerks junger Positionen.</p>
      </li>
      <li>
        <span>seit 2026</span>
        <p>Gründung der Studierenden Galerie Spunst als Ort für Ausstellungen, Editionen und direkte Kunstvermittlung.</p>
      </li>
    </ol>
  </section>
</BaseLayout>
