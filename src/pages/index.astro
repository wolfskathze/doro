---
import BaseLayout from "../layouts/BaseLayout.astro";
import { exhibitions, events } from "../data/site";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Studierenden Galerie Spunst">
  <section class="home-hero">
    <img src={`${base}assets/gallery-hero.png`} alt="Moderner Galerieraum mit kuratierten Kunstwerken" />
    <div class="home-hero-content">
      <p class="eyebrow">Zeitgenössische Galerie</p>
      <h1>Studierenden Galerie Spunst</h1>
      <p>
        Ausstellungen, Kooperationen, Lesungen und Pop-up-Formate rund um die
        kuratorische Arbeit von Dorothea Spunst.
      </p>
      <div class="action-row">
        <a class="button primary" href={`${base}ausstellungen/`}>Ausstellungen</a>
        <a class="button secondary" href={`${base}dorothea/`}>Dorothea Spunst</a>
      </div>
    </div>
  </section>

  <section class="info-strip">
    <article>
      <strong>{exhibitions.length}</strong>
      <span>Ausstellungen im Archiv</span>
    </article>
    <article>
      <strong>{events.length}</strong>
      <span>Events und Formate</span>
    </article>
    <article>
      <strong>IG</strong>
      <span>@galerie_spunst</span>
    </article>
  </section>

  <section class="section split">
    <div>
      <p class="eyebrow">Profil</p>
      <h2>Dorothea Spunst verbindet Galeriearbeit, Forschung und Vermittlung.</h2>
    </div>
    <div class="copy-block">
      <p>
        Die Galerie entsteht als bewegliches Archiv: private Ausstellungsräume,
        Kooperationen mit Karlsruher Orten, studentische Positionen und Formate, die
        zwischen Ausstellung, Gespräch und Einladung liegen.
      </p>
      <a class="text-link" href={`${base}dorothea/`}>Persona ansehen</a>
    </div>
  </section>

  <section class="section">
    <div class="section-heading row">
      <div>
        <p class="eyebrow">Ausblick</p>
        <h2>Aktuelles Programm</h2>
      </div>
      <a class="text-link" href={`${base}events/`}>Alle Events</a>
    </div>
    <div class="feature-list">
      {exhibitions.slice(0, 2).map((item) => (
        <article>
          <span>{item.category}</span>
          <h3>{item.title}</h3>
          <p>{item.dates} / {item.artist}</p>
        </article>
      ))}
      {events.slice(0, 1).map((item) => (
        <article>
          <span>{item.type}</span>
          <h3>{item.title}</h3>
          <p>{item.date}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
