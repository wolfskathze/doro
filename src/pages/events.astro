---
import BaseLayout from "../layouts/BaseLayout.astro";
import InstagramLink from "../components/InstagramLink.astro";
import PageHero from "../components/PageHero.astro";
import { events } from "../data/site";

const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title="Events">
  <PageHero
    eyebrow="Kalender"
    title="Events"
    text="Vernissagen, Finissagen, Lesungen und Pop-up-Formate der Studierenden Galerie Spunst."
  />

  <section class="section event-list">
    {events.map((event) => (
      <article>
        <div class="event-date">{event.date}</div>
        {event.image && <img class="event-image" src={`${base}${event.image}`} alt="" loading="lazy" />}
        <div>
          <p class="eyebrow">{event.type}</p>
          <h2>{event.title}</h2>
          <p>{event.text}</p>
          <InstagramLink href={event.link} />
        </div>
      </article>
    ))}
  </section>
</BaseLayout>
