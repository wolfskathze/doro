---
import BaseLayout from "../../layouts/BaseLayout.astro";
import InstagramLink from "../../components/InstagramLink.astro";
import { exhibitions } from "../../data/site";

export function getStaticPaths() {
  return exhibitions.map((exhibition) => ({
    params: { slug: exhibition.slug },
    props: { exhibition },
  }));
}

const { exhibition } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
---

<BaseLayout title={exhibition.title}>
  <article class="exhibition-detail">
    <header class="detail-hero">
      <a class="text-link" href={`${base}ausstellungen/`}>Zurück zu den Ausstellungen</a>
      <p class="card-meta">{exhibition.category} / {exhibition.dates}</p>
      <h1>{exhibition.title}</h1>
      <p>{exhibition.artist} / {exhibition.venue}</p>
      <InstagramLink href={exhibition.instagram} />
    </header>

    <section class="detail-layout">
      <div class="detail-copy">
        <p>{exhibition.text}</p>
        <p>{exhibition.collaboration}.</p>
        {exhibition.details.map((paragraph) => <p>{paragraph}</p>)}
      </div>

      <div class="detail-gallery">
        {exhibition.images.map((image) => (
          <figure>
            <img src={`${base}${image.src}`} alt={image.alt} loading="lazy" />
            <figcaption>{image.caption}</figcaption>
          </figure>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>
