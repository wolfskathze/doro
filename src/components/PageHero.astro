---
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  image?: string;
}

const { eyebrow, title, text, image } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class={image ? "page-hero image-hero" : "page-hero"}>
  {image && <img src={`${base}${image}`} alt="" aria-hidden="true" />}
  <div>
    <p class="eyebrow">{eyebrow}</p>
    <h1>{title}</h1>
    <p>{text}</p>
  </div>
</section>
