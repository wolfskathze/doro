---
import { exhibitions, menuItems, searchItems } from "../data/site";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Studierenden Galerie Spunst zeigt zeitgenössische Kunst, Ausstellungen, Events und Editionen." } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const siteName = "Studierenden Galerie Spunst";
const pageTitle = title === siteName ? title : `${title} | ${siteName}`;
const pathFor = (href: string) => `${base}${href.replace(/^\//, "")}`;
const searchableItems = [
  ...searchItems,
  ...exhibitions.map((exhibition) => ({
    href: `/ausstellungen/${exhibition.slug}/`,
    title: exhibition.title,
    text: `${exhibition.artist} ${exhibition.category} ${exhibition.dates} ${exhibition.venue}`,
  })),
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
    <link rel="stylesheet" href={`${base}styles/global.css`} />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={pathFor("/")} aria-label="Studierenden Galerie Spunst Startseite">
        <picture class="brand-logo">
          <source srcset={`${base}assets/Logo-white.png`} media="(prefers-color-scheme: dark)" />
          <img src={`${base}assets/Logo-black.png`} alt="Studierenden Galerie Spunst" />
        </picture>
      </a>
      <div class="header-actions">
        <div class="search-shell" data-search-shell>
          <button class="search-toggle" type="button" aria-expanded="false" aria-controls="site-search-panel" data-search-toggle>
            <svg class="search-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <circle cx="10.5" cy="10.5" r="6.5"></circle>
              <path d="M15.2 15.2L20 20"></path>
            </svg>
            <span class="sr-only">Suche öffnen</span>
          </button>
          <form class="site-search" id="site-search-panel" role="search" data-search-form hidden>
            <label class="sr-only" for="site-search">Website durchsuchen</label>
            <input id="site-search" name="q" type="search" placeholder="Suche" autocomplete="off" data-search-input />
            <div class="search-results" data-search-results hidden></div>
          </form>
        </div>
        <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-menu" data-menu-toggle>
          <span></span>
          <span></span>
          <span></span>
          <span class="sr-only">Menü öffnen</span>
        </button>
      </div>
      <nav class="site-menu" id="site-menu" aria-label="Seitennavigation" hidden data-site-menu>
        {menuItems.map((item) => (
          <a href={pathFor(item.href)}>
            <span>{item.label}</span>
            <small>{item.description}</small>
          </a>
        ))}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <p>Studierenden Galerie Spunst</p>
      <nav aria-label="Footer">
        <a href={pathFor("/impressum/")}>Impressum</a>
        <a href={pathFor("/kontakt/")}>Kontakt</a>
      </nav>
    </footer>
    <script type="application/json" id="search-data" set:html={JSON.stringify(searchableItems.map((item) => ({
      ...item,
      href: pathFor(item.href),
    })))}></script>
    <script src={`${base}scripts/site.js`}></script>
  </body>
</html>
